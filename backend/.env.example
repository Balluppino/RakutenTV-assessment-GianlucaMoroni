OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here

# Optional: set the provider explicitly when both keys are available.
LLM_PROVIDER=openai

# Suggested models for each provider. You can change these to other models if you prefer.
OPENAI_MODEL=gpt-4.1-mini # For more quality switch to gpt-4.1
GOOGLE_MODEL=gemini-2.5-flash # For more quality switch to gemini-2.5-pro

# Optional batch defaults for the local demo.
DEFAULT_MAX_ITEMS=10

# Optional Flask local port.
FLASK_PORT=5000
